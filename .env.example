# Copy this file to .env.local and fill in real values from the Supabase dashboard.
# .env.local is gitignored — never commit real credentials.

# ---------- Supabase ----------
# Public (browser-safe). Found in Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Bypasses Row-Level Security. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection. Used by Drizzle (Group B+). Found in
# Supabase dashboard → Project Settings → Database → Connection string (URI).
DATABASE_URL=postgresql://postgres:[password]@db.your-project-ref.supabase.co:5432/postgres
