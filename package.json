{
  "name": "northpoint",
  "version": "0.0.0",
  "private": true,
  "description": "Website editor with an AI brain (placeholder name).",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @northpoint/db db:generate",
    "db:migrate": "pnpm --filter @northpoint/db db:migrate",
    "db:studio": "pnpm --filter @northpoint/db db:studio",
    "db:seed-debug-site": "pnpm --filter @northpoint/db db:seed-debug-site",
    "db:test-e2-storage": "pnpm --filter @northpoint/db db:test-e2-storage"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.75",
    "playwright": "^1.60.0",
    "turbo": "^2.9.14",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "unrs-resolver"]
  }
}
