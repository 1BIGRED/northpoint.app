# Copy to apps/web/.env.local and fill in real values. NEVER commit .env.local.
# Values are referenced by name only in docs/chat (CLAUDE.md §2).

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL and keys from the Supabase dashboard (Project Settings → API).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# Postgres connection string (Supabase → Project Settings → Database). Used by
# Drizzle migrations (pnpm db:migrate) and verification scripts.
DATABASE_URL=postgresql://postgres:[password]@db.your-project-ref.supabase.co:5432/postgres

# ── AI (Group E8 editor chat) ────────────────────────────────────────────────
# Anthropic API key. Without it, the editor loads and manual editing works,
# but the "Ask" AI chat is disabled and shows an inline notice.
# Also add this to the Vercel project env vars for production.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
