{
  "name": "@northpoint/db",
  "version": "0.0.0",
  "private": true,
  "description": "Drizzle schema, migrations, and DB access layer.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "lint": "echo 'no lint yet'",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo",
    "db:generate": "dotenv -e ../../apps/web/.env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../apps/web/.env.local -- drizzle-kit migrate",
    "db:studio": "dotenv -e ../../apps/web/.env.local -- drizzle-kit studio",
    "db:seed-debug-site": "dotenv -e ../../apps/web/.env.local -- node scripts/seed-debug-site.mjs",
    "db:test-e2-storage": "dotenv -e ../../apps/web/.env.local -- node scripts/test-e2-storage.mjs"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  }
}
